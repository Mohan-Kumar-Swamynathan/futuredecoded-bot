# LLM providers (at least one required)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# GitHub Models (fallback after Gemini/Groq; CI uses GITHUB_TOKEN automatically)
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_BASE_URL=https://models.github.ai

# Media
PEXELS_API_KEY=
PIXABAY_API_KEY=

# YouTube — separate from aalaya_mani / am bots
YOUTUBE_CLIENT_SECRETS=config/futuredecoded_client_secrets.json
YOUTUBE_TOKEN_FILE=config/futuredecoded_youtube_token.pickle
YOUTUBE_TOKEN_BASE64=
CLIENT_SECRETS_BASE64=

# Optional social
X_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Pipeline
TREND_SCORE_THRESHOLD=80
TREND_SCORE_FALLBACK_THRESHOLD=50
DATABASE_URL=sqlite:///database/futuredecoded.db
LOG_LEVEL=INFO
DRY_RUN=false

# Cinematic renderer (fullscreen stock video + bottom English subtitles)
USE_CINEMATIC_RENDERER=true
CINEMATIC_FALLBACK_KEN_BURNS=true
STOCK_VIDEO_PROVIDER=pexels
