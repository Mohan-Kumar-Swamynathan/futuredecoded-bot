# LLM providers (at least one required)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Media
PEXELS_API_KEY=
PIXABAY_API_KEY=

# YouTube — separate from aalaya_mani / am bots
YOUTUBE_CLIENT_SECRETS=config/futuredecoded_client_secrets.json
YOUTUBE_TOKEN_FILE=config/futuredecoded_youtube_token.pickle
YOUTUBE_TOKEN_BASE64=
CLIENT_SECRETS_BASE64=

# Optional social
X_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Pipeline
TREND_SCORE_THRESHOLD=80
DATABASE_URL=sqlite:///database/futuredecoded.db
LOG_LEVEL=INFO
DRY_RUN=false
